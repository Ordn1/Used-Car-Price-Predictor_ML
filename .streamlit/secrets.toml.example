# Streamlit Community Cloud or local direct-mode example
# Root-level keys are the safest choice here because Streamlit also exposes them as environment variables.

USED_CAR_RUNTIME_MODE = "direct"
USED_CAR_DB_BACKEND = "supabase"
USED_CAR_SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
USED_CAR_SUPABASE_KEY = "YOUR_SUPABASE_SERVICE_ROLE_KEY"
USED_CAR_SUPABASE_TABLE = "prediction_history"

# Optional local SQLite fallback example:
# USED_CAR_DB_BACKEND = "sqlite"
# USED_CAR_DB_PATH = "streamlit-app/used_car_price_app.db"
